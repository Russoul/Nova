let test0 : в„•
          вү” Z

let test1 : в„• вЁҜ в„• вЁҜ в„•
          вү” Z , S Z , S (S Z)

let test4 : (A : рқ•Ң) вЁҜ A
          вү” в„• , Z

let test31 : Z вүЎ ? вҲҲ в„•
           вү” Refl

define sym : {A : рқ•Ң} вҶ’ {aвӮҖ aвӮҒ : A} вҶ’ (aвӮҖ вүЎ aвӮҒ вҲҲ A) вҶ’ (aвӮҒ вүЎ aвӮҖ вҲҲ A)
           вү” {A aвӮҖ aвӮҒ} вҶҰ a вҶҰ J ? ? (x. e. x вүЎ aвӮҖ вҲҲ A) Refl ? a

define fun-eta : (A : рқ•Ң) вҶ’ (B : A вҶ’ рқ•Ң) вҶ’ (f : (x : A) вҶ’ B x) вҶ’ ((x вҶҰ f x) вүЎ f вҲҲ ((x : A) вҶ’ B x))
               вү” A B f вҶҰ О -О· f

define fun-ext : {A : рқ•Ң} вҶ’ {B : A вҶ’ рқ•Ң} вҶ’ {f g : (x : A) вҶ’ B x} вҶ’ (p : (x : A) вҶ’ f x вүЎ g x вҲҲ B x) вҶ’ f вүЎ g вҲҲ ((x : A) вҶ’ B x)
               вү” {A B f g} вҶҰ p вҶҰ J ? ? (Оұ. h. Оұ вүЎ g вҲҲ ?) (J ? ? (Оұ. h. ?(A , B , f , g , p) вүЎ Оұ вҲҲ ?) (О вҒј (x. ?) (x. ?) (x. p x)) ? (О -О· ?)) ? (О -О· ?)

define happly' : (A : рқ•Ң) вҶ’ (B : рқ•Ң) вҶ’ (f : A вҶ’ B) вҶ’ (g : A вҶ’ B) вҶ’ (p : f вүЎ g вҲҲ ?) вҶ’ (x : A) вҶ’ f x вүЎ g x вҲҲ ?
               вү” A B f g p вҶҰ x вҶҰ J ? ? (Оұ.h. f x вүЎ Оұ x вҲҲ ?) Refl ? p

define happly : (A : рқ•Ң) вҶ’ (B : A вҶ’ рқ•Ң) вҶ’ (f : (x : A) вҶ’ B x) вҶ’ (g : (x : A) вҶ’ B x) вҶ’ (p : f вүЎ g вҲҲ ?) вҶ’ (x : A) вҶ’ f x вүЎ g x вҲҲ ?
              вү” A B f g p x вҶҰ J ? ? (Оұ.h. f x вүЎ Оұ x вҲҲ ?) Refl ? p

define cong : {A B : рқ•Ң} вҶ’ (f : A вҶ’ B) вҶ’ {aвӮҖ aвӮҒ : A} вҶ’ (a : aвӮҖ вүЎ aвӮҒ вҲҲ ?) вҶ’ f aвӮҖ вүЎ f aвӮҒ вҲҲ ?
            вү” {A B} вҶҰ f вҶҰ {aвӮҖ aвӮҒ} вҶҰ a вҶҰ J ? ? (x. h. f aвӮҖ вүЎ f x вҲҲ ?) Refl ? a

define transp : (A : рқ•Ң) вҶ’ (B : A вҶ’ рқ•Ң) вҶ’ {aвӮҖ aвӮҒ : A} вҶ’ (a : aвӮҖ вүЎ aвӮҒ вҲҲ ?) вҶ’ B aвӮҖ вҶ’ B aвӮҒ
              вү” A B вҶҰ {aвӮҖ aвӮҒ} вҶҰ a вҶҰ t вҶҰ J ? ? (Оұ. h. B Оұ) t ? a


let pred' : в„• вҶ’ в„•
          вү” x вҶҰ в„•-elim (x. в„•) Z (x.h. x) x

define pred'-S : (x : в„•) вҶ’ pred' (S x) вүЎ x вҲҲ в„•
               вү” x вҶҰ tac
                   unfold вҳҗ вүЎ _ вҲҲ _;
                   trivial;

define S-cong-inv-H0 : {x y : в„•} вҶ’ (e : pred' (S x) вүЎ pred' (S y) вҲҲ ?) вҶ’ x вүЎ y вҲҲ ?
                     вү” {x y} вҶҰ tac
                          rewriteвҒ»В№ ((x : вҳҗ вүЎ _ вҲҲ _) вҶ’ _) (pred'-S ?);
                          rewriteвҒ»В№ ((x : _ вүЎ вҳҗ вҲҲ _) вҶ’ _) (pred'-S ?);
                          exact id;

define S-cong-inv : {x y : в„•} вҶ’ (e : S x вүЎ S y вҲҲ ?) вҶ’ x вүЎ y вҲҲ ?
                  вү” {x y} вҶҰ e вҶҰ S-cong-inv-H0 (cong pred' e)

let Vect : в„• вҶ’ рқ•Ң вҶ’ рқ•Ң
         вү” n A вҶҰ в„•-elim (x. рқ•Ң) рқҹҷ (x.H. A вЁҜ H) n

let nil : {A : рқ•Ң} вҶ’ Vect Z A
        вү” {A} вҶҰ tac unfold вҳҗ;
                    exact tt;

let Vect-Z : {A : рқ•Ң} вҶ’ Vect Z A вүЎ рқҹҷ вҲҲ рқ•Ң
               вү” {A} вҶҰ tac
                     unfold вҳҗ вүЎ _ вҲҲ _;
                     trivial;

let Vect-S : {A : рқ•Ң} вҶ’ {n : в„•} вҶ’ Vect (S n) A вүЎ A вЁҜ Vect n A вҲҲ рқ•Ң
               вү” {A n} вҶҰ tac
                     unfold вҳҗ вүЎ _ вҲҲ _;
                     unfold _ вүЎ ((x : _) вЁҜ вҳҗ _ _) вҲҲ _;
                     trivial;

define nil-unique : {A : рқ•Ң} вҶ’ (xs : Vect Z A) вҶ’ xs вүЎ nil {A} вҲҲ Vect Z A
                  вү”
                   {A} вҶҰ tac
                      rewriteвҒ»В№ ((x : вҳҗ) вҶ’ _) Vect-Z;
                      rewriteвҒ»В№ ((x : _) вҶ’ _ вүЎ _ вҲҲ вҳҗ) Vect-Z;
                      exact (xs вҶҰ рқҹҷвҒј ? ?);


let _::_ : {A : рқ•Ң} вҶ’ {n : в„•} вҶ’ A вҶ’ Vect n A вҶ’ Vect (S n) A
         вү” {A n} вҶҰ x xs вҶҰ tac
             rewriteвҒ»В№ вҳҗ Vect-S;
             exact x , xs;

define prod-О· : {A B : рқ•Ң} вҶ’ (p : A вЁҜ B) вҶ’ (p .ПҖвӮҒ , p .ПҖвӮӮ) вүЎ p вҲҲ ?
              вү” {A B} вҶҰ p вҶҰ ОЈ-О· p


define Vect-elim-H : {A : рқ•Ң}
                   вҶ’ (P : (n : в„•) вҶ’ Vect n A вҶ’ рқ•Ң)
                   вҶ’ (n : в„•)
                   вҶ’ (xs : A вЁҜ Vect n A)
                   вҶ’ P (S n) (xs .ПҖвӮҒ :: xs .ПҖвӮӮ)
                   вҶ’ P (S n) (tac rewriteвҒ»В№ вҳҗ Vect-S; exact (xs .ПҖвӮҒ , xs .ПҖвӮӮ);)
                   вү” {A} вҶҰ P n xs вҶҰ tac
                       unfold P _ вҳҗ вҶ’ _;
                       exact id;

let Vect-elim : {A : рқ•Ң}
              вҶ’ {n : в„•}
              вҶ’ (P : (n : в„•) вҶ’ Vect n A вҶ’ рқ•Ң)
              вҶ’ (nil : P Z nil)
              вҶ’ (cons : (n : в„•) вҶ’ (x : A) вҶ’ (xs : Vect n A) вҶ’ P n xs вҶ’ P (S n) (x :: xs))
              вҶ’ (xs : Vect n A)
              вҶ’ P n xs
              вү” {A n} вҶҰ P nil cons xs вҶҰ в„•-elim (n. (xs : Vect n A) вҶ’ P n xs)
                  (tac
                       rewriteвҒ»В№ (_ вҶ’ _ вҳҗ) (nil-unique xs);
                       exact (xs вҶҰ nil);
                  )
                  -- (n : в„•) (h : (xs : Vect n A) вҶ’ P n xs) вҠҰ s : (xs : A вЁҜ Vect n A) вҶ’ P (S n) (xs.ПҖвӮҒ, xs.ПҖвӮӮ)
                  -- xs.ПҖвӮҒ : A
                  -- xs.ПҖвӮӮ : Vect n A
                  -- h xs.ПҖвӮӮ : P n xs.ПҖвӮӮ
                  -- cons n xs.ПҖвӮҒ xs.ПҖвӮӮ (h xs.ПҖвӮӮ) : P (S n) (cons xs.ПҖвӮҒ xs.ПҖвӮӮ)
                  (n. h. tac
                    rewriteвҒ»В№ (вҳҗ вҶ’ _) Vect-S;
                    rewrite (_ вҶ’ _ вҳҗ) (ОЈ-О· xs);
                    exact (xs вҶҰ Vect-elim-H P n xs (cons n (xs .ПҖвӮҒ) (xs .ПҖвӮӮ) (h (xs .ПҖвӮӮ))));
                  )
                  n xs

define Vect-elim-nil : {A : рқ•Ң}
                     вҶ’ (P : (n : в„•) вҶ’ Vect n A вҶ’ рқ•Ң)
                     вҶ’ (onNil : P Z nil)
                     вҶ’ (onCons : (n : в„•) вҶ’ (x : A) вҶ’ (xs : Vect n A) вҶ’ P n xs вҶ’ P (S n) (x :: xs))
                     вҶ’ Vect-elim P onNil onCons nil вүЎ onNil вҲҲ ?
                     вү” {A} вҶҰ P onNil onCons вҶҰ tac
                          unfold вҳҗ вүЎ _ вҲҲ _;
                          trivial;

define Vect-elim-cons : {A : рқ•Ң}
                      вҶ’ {n : в„•}
                      вҶ’ (P : (n : в„•) вҶ’ Vect n A вҶ’ рқ•Ң)
                      вҶ’ (onNil : P Z nil)
                      вҶ’ (onCons : (n : в„•) вҶ’ (x : A) вҶ’ (xs : Vect n A) вҶ’ P n xs вҶ’ P (S n) (x :: xs))
                      вҶ’ (x : A)
                      вҶ’ (xs : Vect n A)
                      вҶ’ Vect-elim P onNil onCons (x :: xs) вүЎ onCons n x xs (Vect-elim P onNil onCons xs) вҲҲ ?
                      вү” {A n} вҶҰ P onNil onCons x xs вҶҰ tac
                          unfold вҳҗ вүЎ _ вҲҲ _;
                          unfold вҳҗ вүЎ _ вҲҲ _;
                          unfold onCons _ _ вҳҗ _ вүЎ _ вҲҲ _;
                          unfold onCons _ вҳҗ _ _ вүЎ _ вҲҲ _;
                          unfold onCons _ _ _ (в„•-elim _ _ (xs вҶҰ вҳҗ) n _) вүЎ _ вҲҲ _;
                          unfold onCons _ _ _ (в„•-elim _ _ _ _ вҳҗ) вүЎ _ вҲҲ _;
                          unfold _ вүЎ onCons _ _ _ вҳҗ вҲҲ _;
                          unfold _ вүЎ onCons _ _ _ (в„•-elim _ _ (xs вҶҰ вҳҗ) n _) вҲҲ _;
                          trivial;


-- 0   + y = y
-- S x + y = S (x + y)
let _+_ : в„• вҶ’ в„• вҶ’ в„•
        вү” x y вҶҰ в„•-elim (z. в„•) y (x. h. S h) x

define plus-left-Z : (x : в„•) вҶ’ Z + x вүЎ x вҲҲ в„•
                   вү” x вҶҰ J ? ?
                           (Оұ. h. Оұ Z x вүЎ x вҲҲ в„•)
                           Refl
                           ?
                           (sym !_+_)

define plus-left-S : (t : в„•) вҶ’ (x : в„•) вҶ’ (S t + x) вүЎ S (t + x) вҲҲ в„•
                   вү” t вҶҰ x вҶҰ J ? ?
                               (_@_. h. S t @ x вүЎ S (t @ x) вҲҲ в„•)
                               (cong (the (в„• вҶ’ в„•) (x вҶҰ S x))
                               Refl
                               )
                               ?
                               (sym !_+_)


define plus-right-Z : (x : в„•) вҶ’ x + Z вүЎ x вҲҲ в„•
                    вү” x вҶҰ в„•-elim (x. x + Z вүЎ x вҲҲ в„•)
                                 (J ? ? (Оұ. h. Оұ вүЎ Z вҲҲ в„•) Refl ? (sym (plus-left-Z Z)))
                                 (x. h. J ? ? (Оұ. h. Оұ вүЎ S x вҲҲ в„•) (cong (x вҶҰ S x) h) ? (sym (plus-left-S x Z)))
                                 x


-- (x y : в„•) (h : x + S y вүЎ S (x + y) вҲҲ в„•) вҠҰ S x + S y вүЎ S (S x + y)
--                                           S (x + S y) вүЎ S (S x + y)
--                                           x + S y вүЎ S x + y
--                                           x + S y вүЎ S (x + y)
define plus-right-S : (x y : в„•) вҶ’ (x + S y) вүЎ S (x + y) вҲҲ в„•
                    вү” x y вҶҰ в„•-elim (x. (x + S y) вүЎ S (x + y) вҲҲ в„•)
                                   (tac rewriteвҒ»В№ (вҳҗ вүЎ _ вҲҲ _) (plus-left-Z (S y));
                                        exact (cong (the (в„• вҶ’ в„•) (x вҶҰ S x)) (tac rewriteвҒ»В№ (_ вүЎ вҳҗ вҲҲ _) (plus-left-Z y); trivial;));
                                   )
                                   (x. h. tac rewriteвҒ»В№ (вҳҗ вүЎ _ вҲҲ _) (plus-left-S ? ?);
                                              exact cong (the (в„• вҶ’ в„•) (x вҶҰ S x)) (tac rewriteвҒ»В№ (_ вүЎ вҳҗ вҲҲ _) (plus-left-S ? ?); exact h;);
                                   )
                                   x


define plus-commut : (x y : в„•) вҶ’ x + y вүЎ y + x вҲҲ в„•
                   вү” x y вҶҰ
                      в„•-elim (x. (y : в„•) вҶ’ x + y вүЎ y + x вҲҲ в„•)
                             (y вҶҰ tac
                                rewriteвҒ»В№ (вҳҗ вүЎ _ вҲҲ _) (plus-left-Z ?);
                                rewriteвҒ»В№ (_ вүЎ вҳҗ вҲҲ _) (plus-right-Z ?);
                                trivial;
                             )
                             (x. h. y вҶҰ tac
                               rewriteвҒ»В№ (вҳҗ вүЎ _ вҲҲ _) (plus-left-S ? ?);
                               rewriteвҒ»В№ (_ вүЎ вҳҗ вҲҲ _) (plus-right-S ? ?);
                               exact (cong (x вҶҰ S x) (h ?));
                             )
                             x y

-- 0 * y = 0
-- (1 + x) * y = y + x * y
let _*_ : в„• вҶ’ в„• вҶ’ в„•
        вү” x y вҶҰ в„•-elim (x. в„•) Z (x. h. y + h) x


define mult-left-Z : (x : в„•) вҶ’ Z * x вүЎ Z вҲҲ ?
                    вү” x вҶҰ tac
                        unfold вҳҗ вүЎ _ вҲҲ _;
                        trivial;

define mult-right-Z : (x : в„•) вҶ’ x * Z вүЎ Z вҲҲ ?
                    вү” x вҶҰ tac
                        unfold вҳҗ вүЎ _ вҲҲ _;
                        rewriteвҒ»В№ (в„•-elim _ _ вҳҗ _ вүЎ _ вҲҲ _) (plus-left-Z ?);
                        exact в„•-elim (x. в„•-elim (x. в„•) Z (x.h. h) x вүЎ Z вҲҲ в„•) (tac trivial;) (x. h. tac exact h;) x;


define mult-left-S : (t : в„•) вҶ’ (x : в„•) вҶ’ (S t * x) вүЎ (x + t * x) вҲҲ ?
                   вү” t x вҶҰ tac
                       unfold вҳҗ вүЎ _ вҲҲ _;
                       unfold _ вүЎ _ + вҳҗ вҲҲ _;
                       trivial;


define Nat-eta : (A : в„• вҶ’ рқ•Ң)
               вҶ’ (f : (x : в„•) вҶ’ A x)
               вҶ’ (z : A Z)
               вҶ’ (s : (x : в„•) вҶ’ A x вҶ’ A (S x))
               вҶ’ (f Z вүЎ z вҲҲ ?)
               вҶ’ ((x : в„•) вҶ’ f (S x) вүЎ s x (f x) вҲҲ ?)
               вҶ’ (f вүЎ (x вҶҰ в„•-elim (x. A x) z (x. h. s x h) x) вҲҲ ?)
               вү” A f z s c0 c1 вҶҰ
                  fun-ext
                    (x вҶҰ в„•-elim (x. f x вүЎ в„•-elim (x. A x) z (x.h. s x h) x вҲҲ A x) c0 (x.h. tac rewrite (_ вүЎ _ вҳҗ вҲҲ _) h; exact c1 x;) x)


define trans : {A : рқ•Ң}
             вҶ’ {x y z : A}
             вҶ’ (x вүЎ y вҲҲ A)
             вҶ’ (y вүЎ z вҲҲ A)
             вҶ’ (x вүЎ z вҲҲ A)
             вү” {A x y z} вҶҰ p q вҶҰ
                 tac rewrite (_ вүЎ вҳҗ вҲҲ _) q;
                     rewrite (_ вүЎ вҳҗ вҲҲ _) p;
                     trivial;


-- x + y вүЎ x + z вҶ’ y вүЎ z
define в„•-left-cancel : (x y z : в„•) вҶ’ (x + y вүЎ x + z вҲҲ в„•) вҶ’ (y вүЎ z вҲҲ в„•)
                     вү” x y z p вҶҰ в„•-elim (x. (x + y вүЎ x + z вҲҲ в„•) вҶ’ (y вүЎ z вҲҲ в„•))
                     -- (x : в„•) (y : в„•) (z : в„•) (p : _+_(В·) x y вүЎ _+_(В·) x z вҲҲ в„•)  вҠҰ z : (_+_(В·) 0 y вүЎ _+_(В·) 0 z вҲҲ в„•) вҶ’ (y вүЎ z вҲҲ в„•) (NoSolve)
                       (tac rewriteвҒ»В№ ((x : вҳҗ вүЎ _ вҲҲ _) вҶ’ _) (plus-left-Z ?);
                            rewriteвҒ»В№ ((x : _ вүЎ вҳҗ вҲҲ _) вҶ’ _) (plus-left-Z ?);
                            exact id;)
                     -- (x : в„•) (y : в„•) (z : в„•) (p : _+_(В·) x y вүЎ _+_(В·) x z вҲҲ в„•) (x : в„•) (h : (x + y вүЎ x + z вҲҲ в„•) вҶ’ (y вүЎ z вҲҲ в„•))  вҠҰ
                     -- s : (S (x + y) вүЎ S (x + z) вҲҲ в„•) вҶ’ (y вүЎ z вҲҲ в„•) (NoSolve)
                       (x.h. tac rewriteвҒ»В№ ((x : вҳҗ вүЎ _ вҲҲ _) вҶ’ _) (plus-left-S ? ?);
                                 rewriteвҒ»В№ ((x : _ вүЎ вҳҗ вҲҲ _) вҶ’ _) (plus-left-S ? ?);
                                 exact (t вҶҰ h (S-cong-inv t));
                       )
                       x p

define plus-assoc : (x y z : в„•) вҶ’ x + (y + z) вүЎ (x + y) + z вҲҲ в„•
                  вү” x y z вҶҰ в„•-elim (y. x + (y + z) вүЎ (x + y) + z вҲҲ в„•)
                      -- x + z = x + z
                      (tac rewriteвҒ»В№ (_ вҳҗ вүЎ _ вҲҲ _) (plus-left-Z ?);
                           rewriteвҒ»В№ (_ вүЎ _ вҳҗ _ вҲҲ _) (plus-right-Z ?);
                           exact Refl;
                      )
                      (y. H.
                        tac rewriteвҒ»В№ (_ вҳҗ вүЎ _ вҲҲ _) (plus-left-S ? ?);
                            rewriteвҒ»В№ (вҳҗ вүЎ _ вҲҲ _) (plus-right-S ? ?);
                            rewriteвҒ»В№ (_ вүЎ _ вҳҗ _ вҲҲ _) (plus-right-S ? ?);
                            rewriteвҒ»В№ (_ вүЎ вҳҗ вҲҲ _) (plus-left-S ? ?);
                            exact cong (x вҶҰ S x) H;
                      )
                      y

-- x + y + z + y + z + y + x = x + x + y + y + y + z + z
-- Proof using a commutative-monad solver tactic
-- define test-nat-solver-0 : (x y z : в„•) вҶ’ x + y + z + y + z + y + x вүЎ x + x + y + y + y + z + z вҲҲ в„•
--                          вү” x y z вҶҰ tac normalise-nat вҳҗ вүЎ _ вҲҲ _; trivial;

-- [] ++ ys = ys
-- (x :: xs) ++ ys = x :: (xs ++ ys)

let _++_ : {A : рқ•Ң} вҶ’ {m n : в„•} вҶ’ Vect m A вҶ’ Vect n A вҶ’ Vect (m + n) A
         вү” {A m n} вҶҰ xs ys вҶҰ Vect-elim (m xs вҶҰ Vect (m + n) A)
            (tac rewriteвҒ»В№ (_ вҳҗ _) (plus-left-Z n); exact ys;)
            (m x xs h вҶҰ tac rewriteвҒ»В№ (_ вҳҗ _) (plus-left-S ? ?); rewriteвҒ»В№ вҳҗ Vect-S; exact x, h;)
            xs

let append-left-nil : {A : рқ•Ң} вҶ’ {n : в„•} вҶ’ (xs : Vect n A) вҶ’ nil ++ xs вүЎ (tac rewriteвҒ»В№ (_ вҳҗ _) (plus-left-Z ?); exact xs;) вҲҲ ?
                       вү” {A n} вҶҰ xs вҶҰ
                            tac unfold вҳҗ вүЎ _ вҲҲ _;
                                unfold вҳҗ вүЎ _ вҲҲ _;
                                trivial;

define append-left-cons : {A : рқ•Ң} вҶ’ {m n : в„•} вҶ’ (x : A) вҶ’ (xs : Vect m A) вҶ’ (ys : Vect n A) вҶ’ ((x :: xs) ++ ys вүЎ (tac rewriteвҒ»В№ (_ вҳҗ _) (plus-left-S ? ?); exact x :: (xs ++ ys);) вҲҲ ?)
                        вү” {A m n} вҶҰ x xs ys вҶҰ tac
                            unfold вҳҗ вүЎ _ вҲҲ _;
                            unfold вҳҗ вүЎ _ вҲҲ _;
                            unfold вҳҗ вүЎ _ вҲҲ _;
                            unfold _ вүЎ вҳҗ вҲҲ _;
                            unfold вҳҗ , _ вүЎ _ вҲҲ _;
                            unfold _ вүЎ _ , вҳҗ  вҲҲ _;
                            unfold _ вүЎ _ , вҳҗ вҲҲ _;
                            unfold _ , в„•-elim _ _ _ m вҳҗ вүЎ _ вҲҲ _;
                            trivial;

-- xs ++ [] = xs

define append-right-nil : {A : рқ•Ң} вҶ’ {n : в„•} вҶ’ (xs : Vect n A) вҶ’ xs ++ nil вүЎ (tac rewriteвҒ»В№ (_ вҳҗ _) (plus-right-Z ?); exact xs;) вҲҲ ?
                       вү” {A n} вҶҰ xs вҶҰ Vect-elim (n xs вҶҰ xs ++ nil вүЎ (tac rewriteвҒ»В№ (_ вҳҗ _) (plus-right-Z ?); exact xs;) вҲҲ ?)
                           (tac rewriteвҒ»В№ (вҳҗ вүЎ _ вҲҲ _) (append-left-nil nil); trivial;)
                           (n x xs h вҶҰ tac rewriteвҒ»В№ (вҳҗ вүЎ _ вҲҲ _) (append-left-cons ? ? ?); rewriteвҒ»В№ (_ вҳҗ вүЎ _ вҲҲ _) h; rewriteвҒ»В№ (_ вҳҗ _ _ вүЎ _ вҲҲ _) (plus-right-Z ?); trivial;)
                           xs

-- reverseH xs nil = xs
-- reverseH xs (y :: ys) = reverseH (y :: xs) ys

let reverseH : {A : рқ•Ң} вҶ’ {m n : в„•} вҶ’ Vect m A вҶ’ Vect n A вҶ’ Vect (m + n) A
                вү”  {A m n} вҶҰ xs ys вҶҰ Vect-elim
                     (n ys вҶҰ (m : в„•) вҶ’ Vect m A вҶ’ Vect (m + n) A)
                     (m xs вҶҰ tac rewriteвҒ»В№ (_ вҳҗ _) (plus-right-Z ?); exact xs;)
                     -- h (S m) (y :: xs) : Vect (S m + n)
                     (n y ys h m xs вҶҰ tac rewriteвҒ»В№ (_ вҳҗ _) (plus-right-S ? ?); rewrite (_ вҳҗ _) (plus-left-S ? ?); exact h ? (y :: xs);)
                     ys m xs


-- reverseH xs [] = xs

define reverseH-nil : {A : рқ•Ң} вҶ’ {n : в„•} вҶ’ (xs : Vect n A) вҶ’ reverseH xs nil вүЎ (tac rewriteвҒ»В№ (_ вҳҗ _) (plus-right-Z ?); exact xs;) вҲҲ ?
                   вү” {A n} вҶҰ xs вҶҰ tac unfold вҳҗ вүЎ _ вҲҲ _; rewriteвҒ»В№ (вҳҗ _ _ вүЎ _ вҲҲ _) (Vect-elim-nil (n вҶҰ ys вҶҰ (m : в„•) вҶ’ Vect m A вҶ’ Vect (m + n) A) ? ?); trivial;

-- reverseH xs (y :: ys) = reverse (y :: xs) ys

-- reverseH xs (y :: ys) : Vect (m + S n) A
-- reverseH (y :: xs) ys : Vect (S m + n) A

define reverseH-cons : {A : рқ•Ң} вҶ’ {m n : в„•} вҶ’ (xs : Vect m A) вҶ’ (y : A) вҶ’ (ys : Vect n A) вҶ’
                         (tac rewrite (_ вҳҗ _) (plus-right-S ? ?); exact reverseH xs (y :: ys);)
                            вүЎ
                         (tac rewrite (_ вҳҗ _) (plus-left-S ? ?); exact reverseH (y :: xs) ys;)
                            вҲҲ
                         Vect (S (m + n)) A

-- reverseH xs (y :: ys) = reverseH (y :: xs) ys

                     вү” {A m n} вҶҰ xs y ys вҶҰ tac
                       unfold вҳҗ вүЎ _ вҲҲ _;
                       unfold вҳҗ вүЎ _ вҲҲ _;
                       unfold вҳҗ вүЎ _ вҲҲ _;
                       unfold в„•-elim _ _ (x вҶҰ вҳҗ) _ _ _ _ вүЎ _ вҲҲ _;
                       unfold в„•-elim _ _ _ _ вҳҗ _ _ вүЎ _ вҲҲ _;
                       unfold в„•-elim _ _ _ _ _ _ (вҳҗ :: _) вүЎ _ вҲҲ _;
                       unfold _ вүЎ вҳҗ вҲҲ _;
                       unfold _ вүЎ вҳҗ вҲҲ _;
                       unfold _ вүЎ в„•-elim _ _ (x вҶҰ вҳҗ) _ _ _ _ вҲҲ _;
                       trivial;


-- (_::_(В·) {A} {n} y ys .ПҖвӮӮ)

-- reverse : Vect m вҶ’ Vect n A вҶ’ Vect (m + n)
-- reverse xs [] = xs : Vect (m + 0) A
-- reverse xs (y :: ys) = reverse (y :: xs) ys : Vect (m + S n) A

let reverse : {A : рқ•Ң} вҶ’ {n : в„•} вҶ’ Vect n A вҶ’ Vect n A
            вү” {A n} вҶҰ xs вҶҰ tac rewrite (_ вҳҗ _) (plus-left-Z ?); exact reverseH nil xs;

let _вҲҳ_ : {A B C : рқ•Ң} вҶ’ (B вҶ’ C) вҶ’ (A вҶ’ B) вҶ’ (A вҶ’ C)
        вү” {A B C} вҶҰ g f x вҶҰ g (f x)

let _вү…_ : рқ•Ң вҶ’ рқ•Ң вҶ’ рқ•Ң
        вү” A B вҶҰ (f : A вҶ’ B) вЁҜ (g : B вҶ’ A) вЁҜ (g вҲҳ f вүЎ id вҲҲ ?) вЁҜ (f вҲҳ g вүЎ id вҲҲ ?)

let-type Monoid
     вү” (A : рқ•Ң)
         вЁҜ (z : A)
         вЁҜ (_+_ : A вҶ’ A вҶ’ A)
         вЁҜ ((x : A) вҶ’ z + x вүЎ x вҲҲ A)
         вЁҜ ((x : A) вҶ’ x + z вүЎ x вҲҲ A)
         вЁҜ ((x y z : A) вҶ’ x + (y + z) вүЎ (x + y) + z вҲҲ A)

define Is-Commut-Monoid : рқ•Ң вҶ’ рқ•Ң
     вү” A вҶҰ (z : A)
         вЁҜ (_+_ : A вҶ’ A вҶ’ A)
         вЁҜ ((x : A) вҶ’ z + x вүЎ x вҲҲ A)
         вЁҜ ((x : A) вҶ’ x + z вүЎ x вҲҲ A)
         вЁҜ ((x y z : A) вҶ’ x + (y + z) вүЎ (x + y) + z вҲҲ A)
         вЁҜ ((x y : A) вҶ’ x + y вүЎ y + x вҲҲ A)

define-type Commut-Monoid
     вү” (A : рқ•Ң) вЁҜ Is-Commut-Monoid A

define в„•-Monoid : Monoid
                вү” tac unfold вҳҗ; exact в„•, Z, _+_ , plus-left-Z, plus-right-Z, plus-assoc;

define в„•-Commut-Monoid : Commut-Monoid
                вү” в„•, Z, _+_ , plus-left-Z, plus-right-Z, plus-assoc, plus-commut

define test-commut-monoid-solver : (x y : в„•) вҶ’ x + Z + y + x + x + Z + Z + y вүЎ x + x + Z + y + y + Z + x вҲҲ в„•
                                 вү” x y вҶҰ tac
                                     normalise-comm-monoid (вҳҗ вүЎ _ вҲҲ _) (x y вҠҰ x + 0 + y + x + x + 0 + 0 + y) в„•-Commut-Monoid;
                                     normalise-comm-monoid (_ вүЎ вҳҗ вҲҲ _) (x y вҠҰ x + x + 0 + y + y + 0 + x) в„•-Commut-Monoid;
                                     exact Refl;


let List : рқ•Ң вҶ’ рқ•Ң
         вү” A вҶҰ (n : в„•) вЁҜ Vect n A

let lnil : {A : рқ•Ң} вҶ’ List A
         вү” {A} вҶҰ tac
             unfold вҳҗ;
             exact Z, nil;

let lcons : {A : рқ•Ң} вҶ’ A вҶ’ List A вҶ’ List A
          вү” {A} вҶҰ x вҶҰ tac
              unfold вҳҗ вҶ’ _;
              unfold _ вҶ’ вҳҗ;
              exact (xs вҶҰ S (xs .ПҖвӮҒ) , (tac rewriteвҒ»В№ вҳҗ Vect-S; exact x, xs .ПҖвӮӮ;));

let lrec : {A X : рқ•Ң} вҶ’ X вҶ’ (A вҶ’ List A вҶ’ X вҶ’ X) вҶ’ List A вҶ’ X
         вү” {A X} вҶҰ nil вҶҰ cons вҶҰ xs вҶҰ
             Vect-elim (n vs вҶҰ X) nil (n x xs h вҶҰ cons x (tac unfold вҳҗ; exact n, xs;) h) (the (Vect (tac
               unfold-ctx _ (_ : вҳҗ);
               exact xs .ПҖвӮҒ;
               ) A) (tac unfold-ctx _ (_ : вҳҗ); exact xs .ПҖвӮӮ;))

let lappend : {A : рқ•Ң} вҶ’ List A вҶ’ List A вҶ’ List A
            вү” {A} вҶҰ xs ys вҶҰ lrec {A} {List A} ys (x xs h вҶҰ lcons x h) xs

let one : в„•
        вү” S Z

let two : в„•
        вү” one + one

let four : в„•
   вү” two * two
